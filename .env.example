OPENAI_API_KEY=
OPENAI_MODEL_CHAT=gpt-5.4-mini
FIRSTTRACE_AI_PROVIDER=openai
FIRSTTRACE_INVESTIGATOR=agent
FIRSTTRACE_QUEUE_PROVIDER=filesystem
FIRSTTRACE_CONFIG_PATH=firsttrace.config.yaml
FIRSTTRACE_RECEIVER_TOKEN=
FIRSTTRACE_ALLOW_UNAUTHENTICATED_RECEIVER=false
# Required for protected hosted worker calls. May be the same value as
# FIRSTTRACE_RECEIVER_TOKEN for a small production deployment.
CRON_SECRET=
# Optional. Vercel functions should use /tmp for GitHub materialization cache.
FIRSTTRACE_GITHUB_CACHE_ROOT=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OCI_REGION=
OCI_QUEUE_ID=
OCI_QUEUE_MESSAGES_ENDPOINT=
OCI_QUEUE_POLL_TIMEOUT_SECONDS=20
OCI_QUEUE_VISIBILITY_TIMEOUT_SECONDS=900
OCI_OBJECTSTORAGE_NAMESPACE=
OCI_OBJECTSTORAGE_BUCKET=
OCI_VAULT_ID=
OCI_VAULT_SECRET_NAMES=
OCI_COMPARTMENT_ID=
OCI_VAULT_KEY_ID=
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
# Local fallback only. Prefer a read-only GitHub App for hosted use.
GITHUB_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
