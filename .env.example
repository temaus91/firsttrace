OPENAI_API_KEY=
OPENAI_MODEL_CHAT=gpt-4o-mini
FIRSTTRACE_AI_PROVIDER=openai
FIRSTTRACE_QUEUE_PROVIDER=filesystem
FIRSTTRACE_CONFIG_PATH=firsttrace.config.yaml
FIRSTTRACE_RECEIVER_TOKEN=
FIRSTTRACE_ALLOW_UNAUTHENTICATED_RECEIVER=false
# Required for protected hosted worker calls. May be the same value as
# FIRSTTRACE_RECEIVER_TOKEN for a small dogfood deployment.
CRON_SECRET=
# Optional. Vercel functions should use /tmp for GitHub materialization cache.
FIRSTTRACE_GITHUB_CACHE_ROOT=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
# Local dogfood fallback only. Prefer a read-only GitHub App for hosted use.
GITHUB_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
