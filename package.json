{
  "name": "firsttrace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted bug localization for teams with private, internal, or public git repos.",
  "scripts": {
    "build": "tsc",
    "firsttrace": "tsx src/cli.ts",
    "oci:sync-secrets": "tsx src/oci/sync-secrets.ts",
    "start:http": "node dist/src/runtime/http-server.js",
    "start:worker": "node dist/src/runtime/worker-loop.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "vercel-build": "npm run typecheck"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@supabase/supabase-js": "^2.106.1",
    "@vercel/functions": "^3.6.0",
    "dotenv": "^17.4.2",
    "oci-common": "^2.132.0",
    "oci-objectstorage": "^2.132.0",
    "oci-queue": "^2.132.0",
    "oci-secrets": "^2.132.0",
    "oci-vault": "^2.132.0",
    "openai": "^6.39.0",
    "tar": "^7.5.15",
    "yaml": "^2.8.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/tar": "^6.1.13",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
