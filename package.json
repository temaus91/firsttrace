{
  "name": "firsttrace",
  "version": "0.1.2",
  "type": "module",
  "description": "Self-hosted bug localization for teams with private, internal, or public git repos.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/temaus91/firsttrace.git"
  },
  "bugs": {
    "url": "https://github.com/temaus91/firsttrace/issues"
  },
  "homepage": "https://github.com/temaus91/firsttrace#readme",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "firsttrace": "dist/src/cli.js",
    "firsttrace-http": "dist/src/runtime/http-server.js",
    "firsttrace-oci-sync-secrets": "dist/src/oci/sync-secrets.js",
    "firsttrace-worker": "dist/src/runtime/worker-loop.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./chat/slack/events": {
      "types": "./dist/src/chat/slack/events.d.ts",
      "import": "./dist/src/chat/slack/events.js"
    },
    "./chat/slack/manifest-validator": {
      "types": "./dist/src/chat/slack/manifest-validator.d.ts",
      "import": "./dist/src/chat/slack/manifest-validator.js"
    },
    "./chat/slack/render": {
      "types": "./dist/src/chat/slack/render.d.ts",
      "import": "./dist/src/chat/slack/render.js"
    },
    "./hosted/accept": {
      "types": "./dist/src/hosted/accept.d.ts",
      "import": "./dist/src/hosted/accept.js"
    },
    "./http/receiver": {
      "types": "./dist/src/http/receiver.d.ts",
      "import": "./dist/src/http/receiver.js"
    },
    "./http/vercel-adapter": {
      "types": "./dist/src/http/vercel-adapter.d.ts",
      "import": "./dist/src/http/vercel-adapter.js"
    },
    "./http/worker": {
      "types": "./dist/src/http/worker.d.ts",
      "import": "./dist/src/http/worker.js"
    },
    "./oci/sync-secrets": {
      "types": "./dist/src/oci/sync-secrets.d.ts",
      "import": "./dist/src/oci/sync-secrets.js"
    },
    "./oci/queue-redelivery-probe": {
      "types": "./dist/src/oci/queue-redelivery-probe.d.ts",
      "import": "./dist/src/oci/queue-redelivery-probe.js"
    },
    "./runtime/http-server": {
      "types": "./dist/src/runtime/http-server.d.ts",
      "import": "./dist/src/runtime/http-server.js"
    },
    "./runtime/worker-loop": {
      "types": "./dist/src/runtime/worker-loop.d.ts",
      "import": "./dist/src/runtime/worker-loop.js"
    },
    "./worker/queue-factory": {
      "types": "./dist/src/worker/queue-factory.d.ts",
      "import": "./dist/src/worker/queue-factory.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src/**",
    "README.md",
    "LICENSE",
    "examples/**",
    "deploy/oci/README.md",
    "deploy/oci/Dockerfile.package",
    "deploy/oci/scripts/**",
    "deploy/oci/terraform/*.tf",
    "deploy/oci/terraform/*.example",
    "supabase/migrations/**"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "firsttrace": "tsx src/cli.ts",
    "oci:sync-secrets": "tsx src/oci/sync-secrets.ts",
    "prepack": "npm run build",
    "start:http": "node dist/src/runtime/http-server.js",
    "start:worker": "node dist/src/runtime/worker-loop.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "vercel-build": "npm run typecheck"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@supabase/supabase-js": "^2.106.1",
    "@vercel/functions": "^3.6.0",
    "dotenv": "^17.4.2",
    "oci-common": "^2.132.0",
    "oci-generativeaiinference": "^2.132.0",
    "oci-objectstorage": "^2.132.0",
    "oci-queue": "^2.132.0",
    "oci-secrets": "^2.132.0",
    "oci-vault": "^2.132.0",
    "openai": "^6.39.0",
    "tar": "^7.5.15",
    "yaml": "^2.8.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/tar": "^6.1.13",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
