# Copy this file to terraform.tfvars for local Terraform.
# OCI Resource Manager users can enter the same values as stack variables.

tenancy_ocid     = "ocid1.tenancy.oc1..replace"
compartment_ocid = "ocid1.compartment.oc1..replace"
region           = "us-ashburn-1"
project_name     = "firsttrace"

# First apply:
# container_image_url = ""
#
# After building and pushing the image to OCIR, set:
# container_image_url = "<region-key>.ocir.io/<namespace>/firsttrace:latest"
container_image_url = ""

config_path = "firsttrace.config.yaml"

# OCI-native AI inference. Override ai_model with a model available in your
# selected OCI region, or set ai_provider = "openai" and add OPENAI_API_KEY to
# runtime_secret_names when direct OpenAI API use is intentional.
ai_provider = "oci-genai"
ai_model    = "openai.gpt-oss-120b"

# Use only when you deploy a dedicated OCI GenAI endpoint.
oci_genai_dedicated_endpoint_id = ""

# For a first health-check-only bootstrap, you can set both to false, apply,
# verify /healthz, then create secrets and turn them back on.
enable_vault_secret_loading = true
oci_vault_secrets_required  = true
